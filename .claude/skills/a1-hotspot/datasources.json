{
  "version": "0.3",
  "updated_at": "2026-07-22",
  "output": {
    "path": "data/a1_data/hot_raw_{date}.json",
    "top_n_per_source": 20,
    "dedup": "cross_source_keep",
    "dedup_note": "跨源重复条目保留（重复本身是热度信号），去重判断归 A2",
    "list_types": {
      "hot": "实时热度榜：当前最热内容，按热度绝对值排序",
      "rising": "实时增量榜：上升最快的条目，按增长率/变化量排序"
    }
  },
  "defaults": {
    "method": "GET",
    "timeout_sec": 15,
    "retry": 0,
    "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36"
  },
  "sources": [
    {
      "id": "weibo_hot",
      "name": "微博热搜",
      "platform": "weibo",
      "list_type": "hot",
      "enabled": true,
      "type": "json_api",
      "url": "https://weibo.com/ajax/side/hotSearch",
      "headers": { "Referer": "https://weibo.com/" },
      "params": {},
      "list_path": "data.realtime",
      "field_map": {
        "title": "word",
        "heat_score": "num",
        "rank": "realpos",
        "url": null,
        "domain_tag": "flag_desc",
        "trend": "label_name"
      },
      "url_template": "https://s.weibo.com/weibo?q={title}",
      "default_domain": "综合",
      "heat_meta": {
        "unit": "微博热搜官方加权热度指数",
        "magnitude_observed": "1e6（百万级）",
        "normalization": "pending"
      },
      "probe": {
        "last_verified": "2026-07-19",
        "status": "ok",
        "item_count": 52,
        "sample_file": "a1_data/probe/weibo_hot_search.json"
      },
      "notes": "半官方接口。flag_desc 仅部分条目有值（如“剧集”“综艺”），空时回落 default_domain。label_name 为趋势标记（新/热/爆）"
    },
    {
